		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@typescript-eslint/eslint-plugin": "^8.26.1",
		"@typescript-eslint/parser": "^8.26.1",
		"eslint": "^9",
		"eslint-config-next": "15.2.3",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-jsdoc": "^50.6.8",
		"eslint-plugin-react": "^7.37.4",
