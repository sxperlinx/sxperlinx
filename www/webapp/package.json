	"private": true,
	"scripts": {
		"dev": "node ./src/scripts/dev.mjs",
		"dev:next": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"prettier:write": "prettier . --write",
